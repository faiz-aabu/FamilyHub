@model FamilyHub.Models.NotificationListViewModel

@{
    ViewData["Title"] = "Notifications";
}

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
        <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 mb-4">
            <div>
                <h1 class="h3 fw-bold mb-1">Notifications</h1>
                <p class="text-muted mb-0">Stay up to date with account and family activity.</p>
            </div>
            <form asp-action="MarkAllRead" method="post" class="d-flex gap-2">
                <input type="hidden" name="returnUrl" value="@Url.Action("Index", "Notifications")" />
                @Html.AntiForgeryToken()
                <button class="btn btn-outline-primary rounded-pill">Mark all as read</button>
            </form>
        </div>

        <form method="get" class="row g-3 mb-4">
            <div class="col-12 col-md-4">
                <label class="form-label small fw-semibold text-muted">Search</label>
                <input name="searchTerm" value="@Model.SearchTerm" class="form-control rounded-pill" placeholder="Search notifications" />
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label small fw-semibold text-muted">Type</label>
                <select name="type" class="form-select rounded-pill">
                    <option value="">All types</option>
                    @foreach (var type in Model.AvailableTypes)
                    {
                        <option value="@type" selected="@(Model.SelectedType == type)">@(type)</option>
                    }
                </select>
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label small fw-semibold text-muted">Status</label>
                <select name="readFilter" class="form-select rounded-pill">
                    <option value="all" selected="@(Model.SelectedReadFilter == "all")">All</option>
                    <option value="unread" selected="@(Model.SelectedReadFilter == "unread")">Unread</option>
                    <option value="read" selected="@(Model.SelectedReadFilter == "read")">Read</option>
                </select>
            </div>
            <div class="col-12 col-md-2 d-flex align-items-end">
                <button class="btn btn-dark rounded-pill w-100" type="submit">Filter</button>
            </div>
        </form>

        @if (!Model.Notifications.Any())
        {
            <div class="alert alert-light border rounded-4">You have no notifications for the selected filters.</div>
        }
        else
        {
            <div class="d-grid gap-3">
                @foreach (var notification in Model.Notifications)
                {
                    <div class="notification-card rounded-4 border p-3 @(notification.IsRead ? "bg-white" : "bg-primary-subtle")">
                        <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
                            <div class="d-flex gap-3">
                                <div class="notification-icon"><i class="bi @(!string.IsNullOrWhiteSpace(notification.Icon) ? notification.Icon : "bi-info-circle-fill")"></i></div>
                                <div>
                                    <div class="d-flex align-items-center gap-2 flex-wrap">
                                        <div class="fw-bold">@notification.Title</div>
                                        <span class="badge rounded-pill bg-light text-muted">@notification.Type</span>
                                    </div>
                                    <div class="text-muted small mt-1">@notification.Message</div>
                                    <div class="text-muted mt-2 small">@notification.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm") · @notification.GetTimeAgo()</div>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-2 flex-wrap">
                                @if (!notification.IsRead)
                                {
                                    <form asp-action="MarkRead" asp-route-id="@notification.Id" method="post">
                                        <input type="hidden" name="returnUrl" value="@Url.Action("Index", "Notifications", new { searchTerm = Model.SearchTerm, type = Model.SelectedType, readFilter = Model.SelectedReadFilter, pageNumber = Model.PageNumber })" />
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-success rounded-pill">Mark read</button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="MarkUnread" asp-route-id="@notification.Id" method="post">
                                        <input type="hidden" name="returnUrl" value="@Url.Action("Index", "Notifications", new { searchTerm = Model.SearchTerm, type = Model.SelectedType, readFilter = Model.SelectedReadFilter, pageNumber = Model.PageNumber })" />
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-warning rounded-pill">Mark unread</button>
                                    </form>
                                }
                                @if (!string.IsNullOrWhiteSpace(notification.Link))
                                {
                                    <a class="btn btn-sm btn-outline-secondary rounded-pill" href="@notification.Link">Open</a>
                                }
                                <form asp-action="Delete" asp-route-id="@notification.Id" method="post">
                                    <input type="hidden" name="returnUrl" value="@Url.Action("Index", "Notifications", new { searchTerm = Model.SearchTerm, type = Model.SelectedType, readFilter = Model.SelectedReadFilter, pageNumber = Model.PageNumber })" />
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-danger rounded-pill">Delete</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav class="mt-4" aria-label="Notifications pagination">
                    <ul class="pagination justify-content-center">
                        @for (var pageNumber = 1; pageNumber <= Model.TotalPages; pageNumber++)
                        {
                            <li class="page-item @(pageNumber == Model.PageNumber ? "active" : string.Empty)">
                                <a class="page-link rounded-pill mx-1" asp-action="Index" asp-route-searchTerm="@Model.SearchTerm" asp-route-type="@Model.SelectedType" asp-route-readFilter="@Model.SelectedReadFilter" asp-route-pageNumber="@pageNumber">@pageNumber</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        }
    </div>
</div>
