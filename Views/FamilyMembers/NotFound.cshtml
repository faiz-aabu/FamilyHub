@{
    ViewData["Title"] = "Family Member Not Found";
}

<div class="container py-5">
    <div class="card border-0 shadow-sm rounded-4 text-center p-5">
        <h1 class="display-6 fw-bold mb-3">Family Member Not Found</h1>
        <p class="text-muted mb-4">The family member you are looking for does not exist or may have been removed.</p>
        <a asp-action="Index" class="btn btn-dark rounded-pill px-4">Back to Family Members</a>
    </div>
</div>
