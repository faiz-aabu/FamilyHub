@model IEnumerable<FamilyHub.Models.FamilyMember>

@if (Model.Any())
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
        @foreach (var member in Model)
        {
            <div class="col">
                <div class="card family-card h-100 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                            <img src="@(string.IsNullOrWhiteSpace(member.ImagePath) ? "/images/family/default-avatar.png" : member.ImagePath)"
                                 alt="Profile Picture"
                                 class="rounded-circle me-3"
                                 style="width:70px;height:70px;object-fit:cover;" />
                            <div>
                                <h5 class="fw-bold mb-1">@member.FirstName @member.LastName</h5>
                                <p class="text-muted mb-0">@(string.IsNullOrWhiteSpace(member.Occupation) ? "No occupation" : member.Occupation)</p>
                            </div>
                        </div>

                        <hr />

                        <div class="mb-3">
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">Age</span>
                                <span class="fw-semibold">@(member.Age?.ToString() ?? "Not Available")</span>
                            </div>
                            <div class="d-flex justify-content-between mt-2">
                                <span class="text-muted">Email</span>
                                <span class="fw-semibold">@(string.IsNullOrWhiteSpace(member.Email) ? "Not Provided" : member.Email)</span>
                            </div>
                            <div class="d-flex justify-content-between mt-2">
                                <span class="text-muted">Relationship</span>
                                <span class="fw-semibold">@(string.IsNullOrWhiteSpace(member.Relationship) ? "Not set" : member.Relationship)</span>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <a asp-controller="FamilyMembers" asp-action="Details" asp-route-id="@member.Id" class="btn btn-dark rounded-pill">View Profile</a>
                            <div class="d-flex gap-2">
                                <a asp-controller="FamilyMembers" asp-action="Edit" asp-route-id="@member.Id" class="btn btn-outline-dark rounded-pill flex-grow-1">Edit</a>
                                <button type="button" class="btn btn-outline-danger rounded-pill flex-grow-1 delete-member-btn" data-member-id="@member.Id" data-member-name="@member.FirstName @member.LastName">Delete</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="empty-state text-center py-5 px-4 rounded-4">
        <h3 class="fw-bold text-white mb-3">No matching family members found.</h3>
        <p class="text-light opacity-75">Try a different name, email, phone number, or membership number.</p>
    </div>
}
