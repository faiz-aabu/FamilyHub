@model IEnumerable<FamilyHub.Models.FamilyMember>

@{
    ViewData["Title"] = "Family Members";
    var searchTerm = ViewData["SearchTerm"] as string;
}

<div class="family-dashboard">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start align-items-md-center mb-4 gap-3">
        <div>
            <h1 class="display-6 fw-bold text-white">Family Members</h1>
            <p class="text-light opacity-75 mb-0">
                Manage and view every member of the family.
            </p>
        </div>

        <a asp-action="Create" class="btn btn-light rounded-pill px-4 w-100 w-md-auto">
            ➕ Add Family Member
        </a>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success rounded-4" role="alert">@successMessage</div>
    }

    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="alert alert-danger rounded-4" role="alert">@errorMessage</div>
    }

    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3">
            <div class="input-group flex-wrap gap-2">
                <input id="memberSearch" type="text" class="form-control rounded-pill" placeholder="Search by any detail such as name, email, phone, address, occupation, blood group, hobbies, and more" value="@searchTerm" />
                <button type="button" id="clearSearch" class="btn btn-outline-secondary rounded-pill">Clear</button>
            </div>
        </div>
    </div>

    <div id="memberResults">
        @await Html.PartialAsync("_MemberCardsPartial", Model)
    </div>
</div>

<form id="deleteMemberForm" method="post" asp-action="Delete">
    @Html.AntiForgeryToken()
    <input type="hidden" id="deleteMemberId" name="id" />
</form>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const searchInput = document.getElementById('memberSearch');
            const clearButton = document.getElementById('clearSearch');
            const resultsContainer = document.getElementById('memberResults');
            const deleteForm = document.getElementById('deleteMemberForm');
            const deleteMemberId = document.getElementById('deleteMemberId');

            let searchTimer;

            function performSearch() {
                const searchTerm = searchInput.value.trim();
                const xhr = new XMLHttpRequest();
                xhr.open('GET', '@Url.Action("Index", "FamilyMembers")?searchTerm=' + encodeURIComponent(searchTerm), true);
                xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
                xhr.onreadystatechange = function () {
                    if (xhr.readyState === 4 && xhr.status === 200) {
                        resultsContainer.innerHTML = xhr.responseText;
                    }
                };
                xhr.send();
            }

            searchInput.addEventListener('input', function () {
                clearTimeout(searchTimer);
                searchTimer = setTimeout(performSearch, 250);
            });

            clearButton.addEventListener('click', function () {
                searchInput.value = '';
                performSearch();
            });

            resultsContainer.addEventListener('click', function (event) {
                const button = event.target.closest('.delete-member-btn');
                if (!button) {
                    return;
                }

                const memberId = button.getAttribute('data-member-id');
                window.location.href = '@Url.Action("Delete", "FamilyMembers")/' + memberId;
            });
        });
    </script>
}
