@model FamilyHub.Models.FamilyRelationship

@{
    ViewData["Title"] = "Create Relationship";
}

<h2 class="mb-4">Create Relationship</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="MemberId" class="form-label"></label>
        <select asp-for="MemberId" asp-items="ViewBag.Members" class="form-select"></select>
        <span asp-validation-for="MemberId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="RelationshipType" class="form-label"></label>
        <input asp-for="RelationshipType" class="form-control" />
        <span asp-validation-for="RelationshipType" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="RelatedMemberId" class="form-label"></label>
        <select asp-for="RelatedMemberId" asp-items="ViewBag.Members" class="form-select"></select>
        <span asp-validation-for="RelatedMemberId" class="text-danger"></span>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>
