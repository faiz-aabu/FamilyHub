@model FamilyHub.Models.UserUnlockViewModel

@{
    ViewData["Title"] = "Unlock Account";
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="h3 fw-bold mb-1">Unlock Account</h1>
                <p class="text-muted mb-0">This action removes the current lockout for the selected account.</p>
            </div>
            <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
        </div>

        <div class="alert alert-info" role="alert">
            You are about to unlock <strong>@Model.FullName</strong> (<em>@Model.Email</em>).
        </div>

        <form asp-action="Unlock" method="post">
            <input asp-for="Id" type="hidden" />
            <button type="submit" class="btn btn-info text-white">Unlock Account</button>
        </form>
    </div>
</div>
