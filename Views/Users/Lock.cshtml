@model FamilyHub.Models.UserLockViewModel

@{
    ViewData["Title"] = "Lock Account";
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="h3 fw-bold mb-1">Lock Account</h1>
                <p class="text-muted mb-0">This action locks the selected account until it is unlocked.</p>
            </div>
            <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
        </div>

        <div class="alert alert-warning" role="alert">
            You are about to lock <strong>@Model.FullName</strong> (<em>@Model.Email</em>).
        </div>

        <form asp-action="Lock" method="post">
            <input asp-for="Id" type="hidden" />
            <button type="submit" class="btn btn-warning">Lock Account</button>
        </form>
    </div>
</div>
