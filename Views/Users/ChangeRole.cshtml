@model FamilyHub.Models.UserRoleViewModel

@{
    ViewData["Title"] = "Change Role";
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="h3 fw-bold mb-1">Change Role</h1>
                <p class="text-muted mb-0">Switch the selected account between Admin and User roles.</p>
            </div>
            <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
        </div>

        <form asp-action="ChangeRole" method="post">
            <input asp-for="Id" type="hidden" />
            <div class="mb-3">
                <label class="form-label">User</label>
                <input class="form-control" value="@Model.FullName (@Model.Email)" readonly />
            </div>

            <div class="mb-3">
                <label asp-for="SelectedRole" class="form-label"></label>
                <select asp-for="SelectedRole" asp-items="Model.AvailableRoles" class="form-select"></select>
                <span asp-validation-for="SelectedRole" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Save Role</button>
        </form>
    </div>
</div>
