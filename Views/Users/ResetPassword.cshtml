@model FamilyHub.Models.UserResetPasswordViewModel

@{
    ViewData["Title"] = "Reset Password";
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="h3 fw-bold mb-1">Reset Password</h1>
                <p class="text-muted mb-0">Create a temporary password and require the user to change it on next sign-in.</p>
            </div>
            <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
        </div>

        <div class="alert alert-warning" role="alert">
            This will generate a temporary password and require the user to change it on next login.
        </div>

        <form asp-action="ResetPassword" method="post">
            <input asp-for="Id" type="hidden" />
            <div class="mb-3">
                <label class="form-label">User</label>
                <input class="form-control" value="@Model.FullName (@Model.Email)" readonly />
            </div>
            <button type="submit" class="btn btn-warning">Generate Temporary Password</button>
        </form>
    </div>
</div>
