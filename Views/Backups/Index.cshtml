@model FamilyHub.Models.BackupIndexViewModel

@{
    ViewData["Title"] = "Backup & Restore";
}

<div class="container-fluid px-0">
    <div class="row g-4 mb-4">
        <div class="col-12 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted small mb-2">Last Backup</p>
                            <h3 class="fw-bold mb-1">@(Model.LastBackupDate?.ToLocalTime().ToString("dd MMM yyyy HH:mm") ?? "No backups yet")</h3>
                        </div>
                        <div class="dashboard-icon-wrapper bg-primary-subtle text-primary"><i class="bi bi-cloud-arrow-up-fill"></i></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted small mb-2">Backup Files</p>
                            <h3 class="fw-bold mb-1">@Model.TotalBackupFiles</h3>
                        </div>
                        <div class="dashboard-icon-wrapper bg-info-subtle text-info"><i class="bi bi-files"></i></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted small mb-2">Database Size</p>
                            <h3 class="fw-bold mb-1">@Model.DatabaseSizeDisplay</h3>
                        </div>
                        <div class="dashboard-icon-wrapper bg-success-subtle text-success"><i class="bi bi-hdd-stack-fill"></i></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted small mb-2">Storage Used</p>
                            <h3 class="fw-bold mb-1">@Model.StorageUsedDisplay</h3>
                        </div>
                        <div class="dashboard-icon-wrapper bg-warning-subtle text-warning"><i class="bi bi-box2-fill"></i></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <h1 class="h3 fw-bold mb-1">Backup & Restore</h1>
                    <p class="text-muted mb-0">Create, restore, download, and manage database backups safely.</p>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <form asp-action="Create" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-primary"><i class="bi bi-plus-circle me-2"></i>Create Backup</button>
                    </form>
                    <a class="btn btn-outline-secondary" asp-action="Index"><i class="bi bi-arrow-clockwise me-2"></i>Refresh</a>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <form method="get" class="row g-3 align-items-end mb-4">
                <div class="col-12 col-md-5">
                    <label class="form-label">Search backups</label>
                    <input class="form-control" name="searchTerm" value="@Model.SearchTerm" placeholder="Search by backup name" />
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label">Sort</label>
                    <select class="form-select" name="sortOrder">
                        <option value="newest" selected="@(Model.SortOrder == "newest")">Newest</option>
                        <option value="oldest" selected="@(Model.SortOrder == "oldest")">Oldest</option>
                        <option value="largest" selected="@(Model.SortOrder == "largest")">Largest</option>
                        <option value="smallest" selected="@(Model.SortOrder == "smallest")">Smallest</option>
                    </select>
                </div>
                <div class="col-12 col-md-3">
                    <button class="btn btn-outline-primary w-100" type="submit"><i class="bi bi-funnel me-2"></i>Apply</button>
                </div>
            </form>

            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Backup Name</th>
                            <th>Created Date</th>
                            <th>Created By</th>
                            <th>Size</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Backups.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">No backup files found.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var backup in Model.Backups)
                            {
                                <tr>
                                    <td><strong>@backup.DisplayName</strong></td>
                                    <td>@backup.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                                    <td>@backup.CreatedBy</td>
                                    <td>@backup.SizeDisplay</td>
                                    <td><span class="badge rounded-pill bg-success-subtle text-success">@backup.Status</span></td>
                                    <td>
                                        <div class="d-flex flex-wrap gap-2">
                                            <a class="btn btn-sm btn-outline-primary" asp-action="Download" asp-route-fileName="@backup.FileName"><i class="bi bi-download"></i></a>
                                            <a class="btn btn-sm btn-outline-info" asp-action="Details" asp-route-fileName="@backup.FileName"><i class="bi bi-info-circle"></i></a>
                                            <button class="btn btn-sm btn-outline-success" data-bs-toggle="modal" data-bs-target="#restoreModal-@backup.FileName.Replace('.', '_')"><i class="bi bi-arrow-clockwise"></i></button>
                                            <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#renameModal-@backup.FileName.Replace('.', '_')"><i class="bi bi-pencil"></i></button>
                                            <button class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal-@backup.FileName.Replace('.', '_')"><i class="bi bi-trash"></i></button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const toastEl = document.querySelector('.toast');
        if (toastEl) {
            new bootstrap.Toast(toastEl).show();
        }
    </script>
}

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="toast align-items-center text-bg-success border-0 position-fixed bottom-0 end-0 m-3" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex"><div class="toast-body">@successMessage</div><button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div>
    </div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="toast align-items-center text-bg-danger border-0 position-fixed bottom-0 end-0 m-3" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex"><div class="toast-body">@errorMessage</div><button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div>
    </div>
}

@foreach (var backup in Model.Backups)
{
    var modalId = "restoreModal-" + backup.FileName.Replace('.', '_');
    <div class="modal fade" id="@modalId" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Restore backup</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-2">You are about to restore <strong>@backup.DisplayName</strong>.</p>
                    <p class="text-danger mb-0">Restoring will overwrite the current database state. Continue only if you are sure.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <form asp-action="Restore" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="fileName" value="@backup.FileName" />
                        <button type="submit" class="btn btn-danger">Restore</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    var renameModalId = "renameModal-" + backup.FileName.Replace('.', '_');
    <div class="modal fade" id="@renameModalId" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Rename backup</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form asp-action="Rename" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="oldFileName" value="@backup.FileName" />
                        <label class="form-label">New backup name</label>
                        <input class="form-control" name="newFileName" value="@backup.DisplayName" required />
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Rename</button>
                </div>
            </div>
        </div>
    </div>

    var deleteModalId = "deleteModal-" + backup.FileName.Replace('.', '_');
    <div class="modal fade" id="@deleteModalId" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delete backup</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">Delete <strong>@backup.DisplayName</strong>? This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="fileName" value="@backup.FileName" />
                        <button type="submit" class="btn btn-danger">Delete</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}
