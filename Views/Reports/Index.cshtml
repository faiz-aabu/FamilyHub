@model FamilyHub.Models.ReportsViewModel

@{
    ViewData["Title"] = "Reports & Analytics";
}

<div class="container-fluid px-0">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">Reports & Analytics</h1>
            <p class="text-muted mb-0">Live insights from your family directory and audit activity.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-outline-danger" asp-action="ExportPdf"><i class="bi bi-file-earmark-pdf me-2"></i>Export PDF</a>
            <a class="btn btn-outline-success" asp-action="ExportExcel"><i class="bi bi-file-earmark-excel me-2"></i>Export Excel</a>
            <a class="btn btn-outline-primary" asp-action="Print" target="_blank"><i class="bi bi-printer me-2"></i>Print Report</a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-md-4 col-xl-2">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <div class="text-muted small">Total Members</div>
                    <div class="fw-bold fs-3">@Model.TotalMembers</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4 col-xl-2">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <div class="text-muted small">Male Members</div>
                    <div class="fw-bold fs-3">@Model.MaleMembers</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4 col-xl-2">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <div class="text-muted small">Female Members</div>
                    <div class="fw-bold fs-3">@Model.FemaleMembers</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4 col-xl-2">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <div class="text-muted small">Children</div>
                    <div class="fw-bold fs-3">@Model.Children</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4 col-xl-2">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <div class="text-muted small">Adults</div>
                    <div class="fw-bold fs-3">@Model.Adults</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4 col-xl-2">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <div class="text-muted small">Seniors</div>
                    <div class="fw-bold fs-3">@Model.Seniors</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <div class="text-muted small">Relationships</div>
                    <div class="fw-bold fs-3">@Model.TotalRelationships</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <div class="text-muted small">Families</div>
                    <div class="fw-bold fs-3">@Model.Families</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <div class="text-muted small">Users</div>
                    <div class="fw-bold fs-3">@Model.Users</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <div class="text-muted small">Administrators</div>
                    <div class="fw-bold fs-3">@Model.Administrators</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body">
                    <div class="text-muted small">Recent Activity</div>
                    <div class="fw-bold fs-3">@Model.TotalActivities</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3"><i class="bi bi-gender-ambiguous me-2"></i>Gender Distribution</h5>
                    <canvas id="genderChart" height="220"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3"><i class="bi bi-bar-chart me-2"></i>Age Distribution</h5>
                    <canvas id="ageChart" height="220"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3"><i class="bi bi-calendar3 me-2"></i>Monthly Registrations</h5>
                    <canvas id="registrationChart" height="220"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3"><i class="bi bi-diagram-3 me-2"></i>Relationship Types</h5>
                    <canvas id="relationshipChart" height="220"></canvas>
                </div>
            </div>
        </div>
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3"><i class="bi bi-activity me-2"></i>User Activity</h5>
                    <canvas id="activityChart" height="160"></canvas>
                </div>
            </div>
        </div>
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3"><i class="bi bi-clock-history me-2"></i>Recent Activity</h5>
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Time</th>
                                    <th>User</th>
                                    <th>Action</th>
                                    <th>Description</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.RecentLogs.Any())
                                {
                                    @foreach (var log in Model.RecentLogs)
                                    {
                                        <tr>
                                            <td>@log.Timestamp.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                                            <td>@(string.IsNullOrWhiteSpace(log.UserName) ? "System" : log.UserName)</td>
                                            <td>@log.Action</td>
                                            <td>@log.Description</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="4" class="text-center text-muted py-3">No recent activity recorded.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <script>
        const genderChart = new Chart(document.getElementById('genderChart'), {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.MembersByGender.Select(item => item.Label))),
                datasets: [{ data: @Html.Raw(Json.Serialize(Model.MembersByGender.Select(item => item.Value))), backgroundColor: ['#4f46e5', '#ec4899', '#10b981', '#f59e0b'] }]
            },
            options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
        });

        const ageChart = new Chart(document.getElementById('ageChart'), {
            type: 'bar',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.AgeDistribution.Select(item => item.Label))),
                datasets: [{ label: 'Members', data: @Html.Raw(Json.Serialize(Model.AgeDistribution.Select(item => item.Value))), backgroundColor: '#3b82f6' }]
            },
            options: { responsive: true, scales: { y: { beginAtZero: true } } }
        });

        const registrationChart = new Chart(document.getElementById('registrationChart'), {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.MonthlyRegistrations.Select(item => item.Label))),
                datasets: [{ label: 'Registrations', data: @Html.Raw(Json.Serialize(Model.MonthlyRegistrations.Select(item => item.Value))), borderColor: '#14b8a6', tension: 0.3, fill: false }]
            },
            options: { responsive: true, scales: { y: { beginAtZero: true } } }
        });

        const relationshipChart = new Chart(document.getElementById('relationshipChart'), {
            type: 'pie',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.RelationshipsByType.Select(item => item.Label))),
                datasets: [{ data: @Html.Raw(Json.Serialize(Model.RelationshipsByType.Select(item => item.Value))), backgroundColor: ['#6366f1', '#f43f5e', '#22c55e', '#f59e0b', '#0ea5e9'] }]
            },
            options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
        });

        const activityChart = new Chart(document.getElementById('activityChart'), {
            type: 'bar',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.UserActivity.Select(item => item.Label))),
                datasets: [{ label: 'Actions', data: @Html.Raw(Json.Serialize(Model.UserActivity.Select(item => item.Value))), backgroundColor: '#8b5cf6' }]
            },
            options: { responsive: true, scales: { y: { beginAtZero: true } } }
        });
    </script>
}
