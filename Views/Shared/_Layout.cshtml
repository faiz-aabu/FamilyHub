@{
    var successMessage = TempData["SuccessMessage"] as string;
    var errorMessage = TempData["ErrorMessage"] as string;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FamilyHub</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/family-members.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/family-tree.css" asp-append-version="true" />
</head>
<body data-success-message="@successMessage" data-error-message="@errorMessage">
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm border-bottom" style="backdrop-filter: blur(12px);">
            <div class="container-fluid px-3 px-lg-4">
                <a class="navbar-brand fw-bold d-flex align-items-center gap-2 text-dark flex-shrink-0" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark">F</span>
                    <span>FamilyHub</span>
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto align-items-lg-center flex-nowrap" style="gap: 0.5rem;">
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-pill px-3" asp-controller="Search" asp-action="Index">
                                    <i class="bi bi-search me-2"></i>Search
                                </a>
                            </li>
                        }
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-pill px-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")" asp-area="" asp-controller="Home" asp-action="Dashboard">
                                    <i class="bi bi-house-door me-2"></i>Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-pill px-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "FamilyMembers" ? "active" : "")" asp-area="" asp-controller="FamilyMembers" asp-action="Index">
                                    <i class="bi bi-people me-2"></i>Family Members
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-pill px-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "FamilyRelationships" ? "active" : "")" asp-area="" asp-controller="FamilyRelationships" asp-action="Index">
                                    <i class="bi bi-diagram-3 me-2"></i>Relationships
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-pill px-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "FamilyTree" ? "active" : "")" asp-area="" asp-controller="FamilyTree" asp-action="Index">
                                    <i class="bi bi-tree me-2"></i>Family Tree
                                </a>
                            </li>
                            <li class="nav-item dropdown notification-dropdown">
                                <a class="nav-link nav-pill px-3 position-relative" href="#" id="notificationDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false" title="Notifications">
                                    <i class="bi bi-bell fs-5"></i>
                                    <span id="notificationBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none" style="font-size: 0.65rem;">0</span>
                                </a>
                                <div class="dropdown-menu dropdown-menu-end shadow border-0 rounded-4 p-0 notification-menu" aria-labelledby="notificationDropdown" style="min-width: 320px;">
                                    <div class="d-flex justify-content-between align-items-center px-3 py-3 border-bottom">
                                        <div>
                                            <div class="fw-semibold">Recent notifications</div>
                                            <div class="small text-muted">Latest updates for your account</div>
                                        </div>
                                        <a class="btn btn-link btn-sm text-decoration-none p-0" asp-controller="Notifications" asp-action="Index">View all</a>
                                    </div>
                                    <div id="notificationList" class="p-2"></div>
                                </div>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-lg-center flex-nowrap" style="gap: 0.5rem;">
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle nav-pill nav-pill--admin px-3" href="#" id="systemManagementDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-sliders me-2"></i>System Management
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-4 py-2" aria-labelledby="systemManagementDropdown">
                                        <li>
                                            <a class="dropdown-item rounded-3" asp-area="" asp-controller="Users" asp-action="Index">
                                                <i class="bi bi-people-fill me-2"></i>Manage Users
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item rounded-3" asp-area="" asp-controller="ActivityLogs" asp-action="Index">
                                                <i class="bi bi-journal-text me-2"></i>Audit Logs
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item rounded-3" asp-area="" asp-controller="Reports" asp-action="Index">
                                                <i class="bi bi-bar-chart-line me-2"></i>Reports
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item rounded-3" asp-area="" asp-controller="Backups" asp-action="Index">
                                                <i class="bi bi-cloud-download me-2"></i>Backups
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider" /></li>
                                        <li>
                                            <a class="dropdown-item rounded-3 text-muted" href="#">
                                                <i class="bi bi-plus-circle me-2"></i>Future admin tools
                                            </a>
                                        </li>
                                    </ul>
                                </li>
                            }

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 nav-pill nav-pill--user px-2" href="#" id="userMenuDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="avatar-badge">
                                        <i class="bi bi-person-circle"></i>
                                    </span>
                                    <span class="d-lg-flex flex-column align-items-start" style="min-width: 0;">
                                        <span class="fw-semibold small" style="line-height: 1.1;">
                                            @{
                                                var currentUser = await UserManager.GetUserAsync(User);
                                                var currentUserName = currentUser?.FullName;
                                                var currentUserRole = currentUser is null ? "User" : (await UserManager.IsInRoleAsync(currentUser, "Admin") ? "Admin" : "User");
                                            }
                                            @(string.IsNullOrWhiteSpace(currentUserName) ? currentUser?.Email ?? "User" : currentUserName)
                                        </span>
                                        <span class="small text-muted" style="line-height: 1;">@currentUserRole</span>
                                    </span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-4 py-2" aria-labelledby="userMenuDropdown">
                                    <li>
                                        <a class="dropdown-item rounded-3" asp-area="Identity" asp-controller="Account" asp-action="Manage">
                                            <i class="bi bi-person-badge me-2"></i>My Profile
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item rounded-3" asp-area="Identity" asp-controller="Account" asp-action="Manage">
                                            <i class="bi bi-sliders2 me-2"></i>Manage Account
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <a class="dropdown-item rounded-3 text-danger" asp-area="Identity" asp-controller="Account" asp-action="Logout">
                                            <i class="bi bi-box-arrow-right me-2"></i>Logout
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-pill px-3" asp-area="Identity" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-pill nav-pill--accent px-3" asp-area="Identity" asp-controller="Account" asp-action="Register">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="container py-4 py-lg-5">
        @RenderBody()
    </main>

    <div class="toast-container position-fixed bottom-0 end-0 p-3" id="toastContainer"></div>

    <footer class="footer bg-dark text-white py-4">
        <div class="container text-center">
            <span>FamilyHub © 2026</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        (() => {
            const badge = document.getElementById('notificationBadge');
            const list = document.getElementById('notificationList');
            const dropdownTrigger = document.getElementById('notificationDropdown');

            if (!badge || !list || !dropdownTrigger) {
                return;
            }

            const refreshNotifications = async () => {
                try {
                    const countResponse = await fetch('@Url.Action("UnreadCount", "Notifications")', { credentials: 'same-origin' });
                    if (!countResponse.ok) {
                        return;
                    }

                    const countData = await countResponse.json();
                    const count = typeof countData?.count === 'number' ? countData.count : 0;
                    badge.textContent = count;
                    badge.classList.toggle('d-none', count <= 0);

                    const recentResponse = await fetch('@Url.Action("Recent", "Notifications")', { credentials: 'same-origin' });
                    if (!recentResponse.ok) {
                        list.innerHTML = '<div class="text-muted small px-2 py-3">Notifications are temporarily unavailable.</div>';
                        return;
                    }

                    const recentData = await recentResponse.json();
                    if (!Array.isArray(recentData) || !recentData.length) {
                        list.innerHTML = '<div class="text-muted small px-2 py-3">You have no recent notifications.</div>';
                        return;
                    }

                    list.innerHTML = recentData.map(item => `
                        <a href="${item.link || '#'}" class="d-flex align-items-start gap-2 text-decoration-none text-dark rounded-3 p-2 notification-item">
                            <div class="notification-icon notification-icon--dropdown"><i class="bi ${item.icon || 'bi-info-circle-fill'}"></i></div>
                            <div class="flex-grow-1 min-width-0">
                                <div class="fw-semibold small">${item.title}</div>
                                <div class="text-muted small">${item.message}</div>
                                <div class="text-muted mt-1 small">${item.timeAgo}</div>
                            </div>
                        </a>
                    `).join('');
                } catch (error) {
                    console.warn('Notification refresh failed', error);
                }
            };

            refreshNotifications();
            window.clearInterval(window.__familyHubNotificationTimer);
            window.__familyHubNotificationTimer = window.setInterval(refreshNotifications, 30000);

            if (typeof signalR !== 'undefined' && signalR.HubConnectionBuilder) {
                const connection = new signalR.HubConnectionBuilder()
                    .withUrl('/notificationHub')
                    .withAutomaticReconnect()
                    .build();

                connection.on('ReceiveNotification', () => {
                    refreshNotifications();
                });

                connection.start().catch(() => {
                    console.info('SignalR unavailable, falling back to polling.');
                });
            }
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
