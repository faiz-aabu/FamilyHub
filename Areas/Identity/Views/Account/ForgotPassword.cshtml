@{
    // This page keeps the same polished card layout used across the rest of FamilyHub.
    ViewData["Title"] = "Forgot Password";
}

<div class="row justify-content-center py-5">
    <div class="col-12 col-md-8 col-lg-5">
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="hero-card text-white p-4 p-md-5 text-center">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle hero-badge p-3 mb-3">
                    <span class="fs-3">🔐</span>
                </div>
                <h1 class="h3 fw-bold mb-2">Reset your password</h1>
                <p class="mb-0 text-light">Support for password recovery can be expanded here while keeping the FamilyHub experience consistent.</p>
            </div>

            <div class="card-body p-4 p-md-5">
                <div class="alert alert-light rounded-3 border-0" role="alert">
                    Password reset is not yet fully configured, but this page now matches the rest of the app visually.
                </div>
                <a asp-page="./Login" class="btn btn-outline-dark rounded-pill px-4">Back to login</a>
            </div>
        </div>
    </div>
</div>
