@page
@{
    // This page appears when an authenticated user tries to reach a page that requires a higher role.
    ViewData["Title"] = "Access denied";
}

<div class="row justify-content-center py-5">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="hero-card text-white p-4 p-md-5 text-center">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle hero-badge p-3 mb-3">
                    <span class="fs-3">🔒</span>
                </div>
                <h1 class="h3 fw-bold mb-2">Access denied</h1>
                <p class="mb-0 text-light">You do not have permission to access this page.</p>
            </div>
            <div class="card-body p-4 p-md-5 text-center">
                <a asp-controller="Home" asp-action="Index" class="btn btn-dark rounded-pill px-4">Return to Dashboard</a>
            </div>
        </div>
    </div>
</div>
