@page
@{
    ViewData["Title"] = "Forgot password confirmation";
}

<div class="row justify-content-center py-5">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="hero-card text-white p-4 p-md-5 text-center">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle hero-badge p-3 mb-3">
                    <span class="fs-3">✉️</span>
                </div>
                <h1 class="h3 fw-bold mb-2">Check your inbox</h1>
                <p class="mb-0 text-light">If an account exists for the provided email, a reset link has been queued.</p>
            </div>
            <div class="card-body p-4 p-md-5 text-center">
                <a asp-page="./Login" class="btn btn-dark rounded-pill px-4">Back to login</a>
            </div>
        </div>
    </div>
</div>
