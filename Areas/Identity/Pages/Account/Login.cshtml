@page
@model FamilyHub.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center py-5">
    <div class="col-12 col-md-8 col-lg-5">
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="hero-card text-white p-4 p-md-5 text-center">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle hero-badge p-3 mb-3">
                    <span class="fs-3">👨‍👩‍👧‍👦</span>
                </div>
                <h1 class="h3 fw-bold mb-2">Welcome back</h1>
                <p class="mb-0 text-light">Sign in to continue managing your family records.</p>
            </div>

            <div class="card-body p-4 p-md-5">
                <form method="post" novalidate>
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Input.Email" class="form-control rounded-end-3 border-0 bg-light" placeholder="name@example.com" />
                        </div>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0"><i class="bi bi-lock"></i></span>
                            <input asp-for="Input.Password" class="form-control rounded-end-3 border-0 bg-light password-toggle-field" placeholder="Enter password" />
                            <button type="button" class="btn btn-outline-secondary password-toggle-button" aria-label="Show password"><i class="bi bi-eye"></i></button>
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="Input.RememberMe" class="form-check-input" />
                        <label asp-for="Input.RememberMe" class="form-check-label text-muted"></label>
                    </div>

                    <button type="submit" class="btn btn-dark rounded-pill px-4 py-2 w-100 mb-3">Login</button>

                    <div class="d-flex flex-column flex-sm-row justify-content-between gap-2 small">
                        <a asp-page="./Register" class="text-decoration-none fw-semibold">Create an account</a>
                        <a asp-page="./ForgotPassword" class="text-decoration-none fw-semibold">Forgot password?</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
