@page
@model FamilyHub.Areas.Identity.Pages.Account.ManageModel

@{
    ViewData["Title"] = "Manage Account";
    var profileImage = string.IsNullOrWhiteSpace(Model.ManageAccount.ProfilePicturePath)
        ? "/images/family/default-avatar.png"
        : Model.ManageAccount.ProfilePicturePath;
}

<div class="container py-4">
    <div class="row g-4">
        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                <div class="hero-card text-white p-4">
                    <div class="d-flex align-items-center gap-3">
                        <img src="@profileImage" alt="Profile" class="rounded-circle border border-4 border-white shadow" style="width: 72px; height: 72px; object-fit: cover;" />
                        <div>
                            <h2 class="h5 fw-bold mb-1">@Model.ManageAccount.FullName</h2>
                            <p class="mb-0 text-light-emphasis">@User.Identity?.Name</p>
                        </div>
                    </div>
                </div>
                <div class="card-body p-4">
                    <div class="d-flex flex-column gap-2 text-muted">
                        <div><i class="bi bi-calendar-event me-2"></i>Joined @((Model.ManageAccount.AccountCreatedAt is null) ? "recently" : Model.ManageAccount.AccountCreatedAt.Value.ToLocalTime().ToString("dd MMM yyyy"))</div>
                        <div><i class="bi bi-shield-check me-2"></i>Role: @Model.ManageAccount.CurrentRole</div>
                        <div><i class="bi bi-clock-history me-2"></i>Last login: @((Model.ManageAccount.LastLoginAt is null) ? "Not recorded" : Model.ManageAccount.LastLoginAt.Value.ToLocalTime().ToString("dd MMM yyyy HH:mm"))</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 p-md-5">
                    @if (TempData["SuccessMessage"] is string success)
                    {
                        <div class="alert alert-success rounded-4" role="alert">@success</div>
                    }
                    @if (TempData["ErrorMessage"] is string error)
                    {
                        <div class="alert alert-danger rounded-4" role="alert">@error</div>
                    }

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <h1 class="h3 fw-bold mb-1">Account Settings</h1>
                            <p class="text-muted mb-0">Manage your profile, security, and account preferences.</p>
                        </div>
                    </div>

                    <div class="row g-4">
                        <div class="col-12">
                            <div class="border rounded-4 p-4">
                                <h5 class="fw-bold mb-3"><i class="bi bi-person-lines-fill me-2"></i>Profile</h5>
                                <form asp-controller="Account" asp-action="Manage" asp-area="Identity" method="post" enctype="multipart/form-data">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="actionType" value="profile" />
                                    <div class="row g-3">
                                        <div class="col-12 col-md-6">
                                            <label asp-for="ManageAccount.FullName" class="form-label"></label>
                                            <input asp-for="ManageAccount.FullName" class="form-control" />
                                            <span asp-validation-for="ManageAccount.FullName" class="text-danger small"></span>
                                        </div>
                                        <div class="col-12 col-md-6">
                                            <label asp-for="ManageAccount.UserName" class="form-label"></label>
                                            <input asp-for="ManageAccount.UserName" class="form-control" />
                                            <span asp-validation-for="ManageAccount.UserName" class="text-danger small"></span>
                                        </div>
                                        <div class="col-12 col-md-6">
                                            <label asp-for="ManageAccount.Email" class="form-label"></label>
                                            <input asp-for="ManageAccount.Email" class="form-control" />
                                            <span asp-validation-for="ManageAccount.Email" class="text-danger small"></span>
                                        </div>
                                        <div class="col-12 col-md-6">
                                            <label asp-for="ManageAccount.PhoneNumber" class="form-label"></label>
                                            <input asp-for="ManageAccount.PhoneNumber" class="form-control" />
                                            <span asp-validation-for="ManageAccount.PhoneNumber" class="text-danger small"></span>
                                        </div>
                                        <div class="col-12 col-md-6">
                                            <label asp-for="ManageAccount.CurrentPassword" class="form-label"></label>
                                            <input asp-for="ManageAccount.CurrentPassword" class="form-control" />
                                            <span asp-validation-for="ManageAccount.CurrentPassword" class="text-danger small"></span>
                                            <div class="form-text">Required when changing your email address.</div>
                                        </div>
                                    </div>
                                    <div class="mt-3 d-flex flex-wrap justify-content-between gap-2">
                                        <button type="submit" class="btn btn-primary rounded-pill"><i class="bi bi-save me-2"></i>Save Changes</button>
                                        <a class="btn btn-outline-secondary rounded-pill" asp-page="./Manage"><i class="bi bi-x-circle me-2"></i>Cancel</a>
                                    </div>
                                </form>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="border rounded-4 p-4">
                                <h5 class="fw-bold mb-3"><i class="bi bi-key-fill me-2"></i>Change Password</h5>
                                <form asp-controller="Account" asp-action="Manage" asp-area="Identity" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="actionType" value="password" />
                                    <div class="row g-3">
                                        <div class="col-12">
                                            <label asp-for="ManageAccount.CurrentPassword" class="form-label"></label>
                                            <div class="input-group">
                                                <input asp-for="ManageAccount.CurrentPassword" class="form-control password-toggle-field" />
                                                <button type="button" class="btn btn-outline-secondary password-toggle-button" aria-label="Show password"><i class="bi bi-eye"></i></button>
                                            </div>
                                            <span asp-validation-for="ManageAccount.CurrentPassword" class="text-danger small"></span>
                                        </div>
                                        <div class="col-12 col-md-6">
                                            <label asp-for="ManageAccount.NewPassword" class="form-label"></label>
                                            <div class="input-group">
                                                <input asp-for="ManageAccount.NewPassword" class="form-control password-toggle-field" />
                                                <button type="button" class="btn btn-outline-secondary password-toggle-button" aria-label="Show password"><i class="bi bi-eye"></i></button>
                                            </div>
                                            <span asp-validation-for="ManageAccount.NewPassword" class="text-danger small"></span>
                                        </div>
                                        <div class="col-12 col-md-6">
                                            <label asp-for="ManageAccount.ConfirmPassword" class="form-label"></label>
                                            <div class="input-group">
                                                <input asp-for="ManageAccount.ConfirmPassword" class="form-control password-toggle-field" />
                                                <button type="button" class="btn btn-outline-secondary password-toggle-button" aria-label="Show password"><i class="bi bi-eye"></i></button>
                                            </div>
                                            <span asp-validation-for="ManageAccount.ConfirmPassword" class="text-danger small"></span>
                                        </div>
                                    </div>
                                    <div class="mt-3 d-flex justify-content-end">
                                        <button type="submit" class="btn btn-outline-dark rounded-pill"><i class="bi bi-shield-lock me-2"></i>Change Password</button>
                                    </div>
                                </form>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="border rounded-4 p-4">
                                <h5 class="fw-bold mb-3"><i class="bi bi-image me-2"></i>Profile Picture</h5>
                                <form asp-controller="Account" asp-action="Manage" asp-area="Identity" method="post" enctype="multipart/form-data">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="actionType" value="picture" />
                                    <div class="d-flex flex-column flex-md-row align-items-md-center gap-3">
                                        <input type="file" class="form-control" name="ProfilePictureFile" accept="image/*" />
                                        <button type="submit" class="btn btn-outline-primary rounded-pill"><i class="bi bi-upload me-2"></i>Upload</button>
                                    </div>
                                </form>
                                <form asp-controller="Account" asp-action="Manage" asp-area="Identity" method="post" class="mt-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="actionType" value="remove-picture" />
                                    <button type="submit" class="btn btn-outline-danger rounded-pill"><i class="bi bi-trash3 me-2"></i>Remove Profile Picture</button>
                                </form>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="border rounded-4 p-4">
                                <h5 class="fw-bold mb-3"><i class="bi bi-fingerprint me-2"></i>Security</h5>
                                <form asp-controller="Account" asp-action="Manage" asp-area="Identity" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="actionType" value="2fa" />
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" asp-for="ManageAccount.EnableTwoFactor" />
                                        <label class="form-check-label fw-semibold" asp-for="ManageAccount.EnableTwoFactor"></label>
                                    </div>
                                    <p class="text-muted small mt-2 mb-0">Two-factor authentication is prepared for your account and will be enabled once email delivery is configured.</p>
                                    <div class="mt-3 d-flex justify-content-end">
                                        <button type="submit" class="btn btn-outline-secondary rounded-pill"><i class="bi bi-shield-check me-2"></i>Save Security Settings</button>
                                    </div>
                                </form>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="border rounded-4 p-4 border-danger-subtle">
                                <h5 class="fw-bold mb-3 text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Delete Account</h5>
                                <p class="text-muted mb-3">This action is permanent and will remove your account and associated profile data.</p>
                                <form asp-controller="Account" asp-action="Manage" asp-area="Identity" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="actionType" value="delete" />
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" asp-for="ManageAccount.ConfirmDelete" />
                                        <label class="form-check-label" asp-for="ManageAccount.ConfirmDelete">I understand that deleting my account is permanent.</label>
                                    </div>
                                    <div class="mt-3 d-flex justify-content-end">
                                        <button type="submit" class="btn btn-danger rounded-pill"><i class="bi bi-trash3 me-2"></i>Delete Account</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
